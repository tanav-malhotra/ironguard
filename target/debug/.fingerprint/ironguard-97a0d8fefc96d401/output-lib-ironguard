f>`.\n"},"level":"error","spans":[{"file_name":"src\\scanners\\mod.rs","byte_start":3638,"byte_end":3649,"line_start":117,"line_end":117,"column_start":35,"column_end":46,"is_primary":true,"text":[{"text":"    scanners: HashMap<String, Box<dyn Scanner>>,","highlight_start":35,"highlight_end":46}],"label":"`Scanner` is not dyn compatible","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"for a trait to be dyn compatible it needs to allow building a vtable\nfor more information, visit <https://doc.rust-lang.org/reference/items/traits.html#dyn-compatibility>","code":null,"level":"note","spans":[{"file_name":"src\\scanners\\mod.rs","byte_start":3214,"byte_end":3221,"line_start":105,"line_end":105,"column_start":11,"column_end":18,"is_primary":false,"text":[{"text":"pub trait Scanner: Send + Sync {","highlight_start":11,"highlight_end":18}],"label":"this trait is not dyn compatible...","suggested_replacement":null,"suggestion_applicability":null,"expansion":null},{"file_name":"src\\scanners\\mod.rs","byte_start":3372,"byte_end":3376,"line_start":110,"line_end":110,"column_start":14,"column_end":18,"is_primary":true,"text":[{"text":"    async fn scan(&self) -> Result<Vec<Vulnerability>>;","highlight_start":14,"highlight_end":18}],"label":"...because method `scan` is `async`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null},{"file_name":"src\\scanners\\mod.rs","byte_start":3429,"byte_end":3432,"line_start":111,"line_end":111,"column_start":14,"column_end":17,"is_primary":true,"text":[{"text":"    async fn fix(&self, vulnerability: &Vulnerability) -> Result<()>;","highlight_start":14,"highlight_end":17}],"label":"...because method `fix` is `async`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"consider moving `scan` to another trait","code":null,"level":"help","spans":[],"children":[],"rendered":null},{"message":"co